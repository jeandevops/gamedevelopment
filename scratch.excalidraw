    {
      "id": "AlIvTl2NZdRsB6L8jRh8Q",
      "type": "text",
      "x": 1229.936736593934,
      "y": 548.656889696078,
      "width": 690.75,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a18072",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1t",
      "roundness": null,
      "seed": 677611547,
      "version": 1393,
      "versionNonce": 193364307,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1768088857218,
      "link": null,
      "locked": false,
      "text": "- Plan A: The server dictates how the things move on the screen.\n            The clients only send the commands.\n- Plan B: The player move freely and everything else move based\n            on what we receive from server.\nObs: Don't matter the apprach the use of linear interpolation (LERP)\n      based on the client's latency against the server. A threshold\n      should be implemented to preserve the gameplay's quality.\n\nExtra: Study what is more performatic:\n         - End the player session when it enter in combat and treat the\n           combat in this new session\n         - Mantain the player session all the time!",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Plan A: The server dictates how the things move on the screen.\n            The clients only send the commands.\n- Plan B: The player move freely and everything else move based\n            on what we receive from server.\nObs: Don't matter the apprach the use of linear interpolation (LERP)\n      based on the client's latency against the server. A threshold\n      should be implemented to preserve the gameplay's quality.\n\nExtra: Study what is more performatic:\n         - End the player session when it enter in combat and treat the\n           combat in this new session\n         - Mantain the player session all the time!",
      "autoResize": true,
      "lineHeight": 1.25
    },
