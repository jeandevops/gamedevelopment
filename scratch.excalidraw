      "link": null,
      "locked": false,
      "text": "Boss Fight!\nYes    No",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "qfD-YzSLHFM-avBvUVEYq",
      "originalText": "Boss Fight!\nYes    No",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ns3YFORGDsLMo7Rx9oy5g",
      "type": "text",
      "x": 459.06408992463844,
      "y": 1808.2158783478944,
      "width": 482.45001220703125,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#d2bab0",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3X",
      "roundness": null,
      "seed": 339734707,
      "version": 1042,
      "versionNonce": 1703582355,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1768089057778,
      "link": null,
      "locked": false,
      "text": "The players will be able to defeat bosses just\none time per day. The boss fight will be different\nfrom the other mob fights. You can enter with or\nwithout your party. And a message will be\npoped up.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The players will be able to defeat bosses just\none time per day. The boss fight will be different\nfrom the other mob fights. You can enter with or\nwithout your party. And a message will be\npoped up.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "-0QoN5419oi06tHA8W4aN",
      "type": "text",
      "x": 2315.477093792434,
      "y": 162.48494944797045,
      "width": 215.11666870117188,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a18072",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3Y",
