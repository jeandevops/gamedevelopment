      "updated": 1767919613460,
      "link": null,
      "locked": false,
      "text": "When a player engage in combat, the others\nappears static and in shades of gray (unless\nthey are in the same party).\nWhen the battle is over, only the winners return to\nthe original grid.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When a player engage in combat, the others\nappears static and in shades of gray (unless\nthey are in the same party).\nWhen the battle is over, only the winners return to\nthe original grid.",
