      "link": null,
      "locked": false,
      "text": "The World is bigger than what the player can see, so when it explores the map\nthe tiles will be rendered based on what the camara área reviews.\nThe maps are build in structures like this:\n\n                   00000000000000000\n                   00001222100000000\n                   00012222210000000\n\nAnd will be rendered properly based on the tile meaning (1 corner, 2 water, etc)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The World is bigger than what the player can see, so when it explores the map\nthe tiles will be rendered based on what the camara área reviews.\nThe maps are build in structures like this:\n\n                   00000000000000000\n                   00001222100000000\n                   00012222210000000\n\nAnd will be rendered properly based on the tile meaning (1 corner, 2 water, etc)",
      "autoResize": true,
      "lineHeight": 1.25
    },
