    },
    {
      "id": "qSLqY3s20X2uOMm_1Dota",
      "type": "text",
      "x": 1262.7036037340488,
      "y": 1629.212324865751,
      "width": 871.5166625976562,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a18072",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3E",
      "roundness": null,
      "seed": 728051485,
      "version": 2152,
      "versionNonce": 1682861469,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1768088857218,
      "link": null,
      "locked": false,
      "text": "Extra: Think about decorative scenario objects with perspective (like frames for painting\nand the painting, in this case will be the playable tiles). These object will have only\ndecorative purpose.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Extra: Think about decorative scenario objects with perspective (like frames for painting\nand the painting, in this case will be the playable tiles). These object will have only\ndecorative purpose.",
      "autoResize": true,
      "lineHeight": 1.25
    },
