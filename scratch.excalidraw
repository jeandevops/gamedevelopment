      "boundElements": [],
      "updated": 1768088910186,
      "link": null,
      "locked": false,
      "text": "PLAYER BUILD",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "PLAYER BUILD",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "hnEStO7_N_9RjjRkmIc5A",
      "type": "text",
      "x": 2167.986264777721,
      "y": 278.8182078926373,
      "width": 519.433349609375,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a18072",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3Z",
      "roundness": null,
      "seed": 158687187,
      "version": 1930,
      "versionNonce": 1265331101,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1768090154699,
      "link": null,
      "locked": false,
      "text": "Initially only three atributes (keep it simple):\n - Power: How good you hit\n - Defence: How good you do not get hitted;\n - Shrewdness: How aware of the enemies you are\n\nYou will need to think hard about the balance of this\n(or use an A.I. agent to help you think)\n\nOnce you got the \"framework\" done, you will have to\nthink about the history.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Initially only three atributes (keep it simple):\n - Power: How good you hit\n - Defence: How good you do not get hitted;\n - Shrewdness: How aware of the enemies you are\n\nYou will need to think hard about the balance of this\n(or use an A.I. agent to help you think)\n\nOnce you got the \"framework\" done, you will have to\nthink about the history.",
      "autoResize": true,
      "lineHeight": 1.25
    },
